# TERX environment configuration
# Copy this file to .env and fill in your values.
# .env is gitignored — never commit it.

# ------------------------------------------------------------------ #
# Benchmark credentials (optional — only needed for terx-bench-real)
# ------------------------------------------------------------------ #

# Groq API key — get one free at https://console.groq.com
# Used by: python -m terx.benchmarks.real_agent
GROQ_API_KEY=

# Self-healing credentials (optional — only needed for litellm self-healing)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ------------------------------------------------------------------ #
# Benchmark config (optional)
# ------------------------------------------------------------------ #

# Override ports when running the real benchmark in constrained environments.
TERX_BENCH_PORT=
TERX_CDP_PORT=

# Limit real benchmark tasks during smoke tests. Empty = all tasks.
TERX_BENCH_TASK_LIMIT=

# ------------------------------------------------------------------ #
# TERX runtime config (optional)
# ------------------------------------------------------------------ #

# Enable debug logging (1 = on, default: 0)
TERX_DEBUG=

# Force all typed values through replay placeholders.
TERX_REDACT_ALL_TEXT=

# Comma-separated extra sensitive field labels.
TERX_REDACT_FIELDS=
