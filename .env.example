# TERX environment configuration
# Copy this file to .env and fill in your values.
# .env is gitignored — never commit it.

# ------------------------------------------------------------------ #
# Benchmark credentials (optional — only needed for terx-bench-real)
# ------------------------------------------------------------------ #

# Groq API key — get one free at https://console.groq.com
# Used by: python -m terx.benchmarks.real_agent
GROQ_API_KEY=

# OpenAI API key (alternative LLM provider for benchmarks)
OPENAI_API_KEY=

# ------------------------------------------------------------------ #
# TERX server config (optional — all have sensible defaults)
# ------------------------------------------------------------------ #

# Chrome remote debugging endpoint (default: ws://localhost:9222)
TERX_CDP_URL=

# Path for SQLite cache file (default: ~/.terx/cache.db)
TERX_CACHE_PATH=

# Cache similarity threshold 0.0-1.0 (default: 0.85)
TERX_SIMILARITY_THRESHOLD=

# Enable debug logging (1 = on, default: 0)
TERX_DEBUG=
